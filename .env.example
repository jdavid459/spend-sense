# demo or private
SPEND_DATA_MODE=demo

# Path used when SPEND_DATA_MODE=private
PRIVATE_CHASE_CSV=data/private/chase_transactions.csv

# Path used when SPEND_DATA_MODE=demo
DEMO_CHASE_CSV=data/demo/chase_transactions_demo.csv

# DuckDB database path
DUCKDB_PATH=duckdb/spend_sense.duckdb

# Optional Cohere integration
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-english-v3.0
COHERE_RERANK_MODEL=rerank-v3.5
COHERE_EMBED_BATCH_SIZE=96
MERCHANT_PROFILE_BATCH_SIZE=10
